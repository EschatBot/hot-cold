    <meta name="citation_reference" content="citation_journal_title=Journal of Nonverbal Behavior; citation_title=On measuring performance in category judgment studies of nonverbal behavior; citation_author=HL Wagner; citation_volume=17; citation_issue=1; citation_publication_date=1993; citation_pages=3-28; citation_doi=10.1007/BF00987006; citation_id=CR59"/>
    <meta name="citation_reference" content="citation_journal_title=Journal of Personality and Social Psychology; citation_title=Development and validation of brief measures of positive and negative affect: The PANAS scales; citation_author=D Watson, LA Clark, A Tellegen; citation_volume=54; citation_issue=6; citation_publication_date=1988; citation_pages=1063-1070; citation_doi=10.1037/0022-3514.54.6.1063; citation_id=CR60"/>
