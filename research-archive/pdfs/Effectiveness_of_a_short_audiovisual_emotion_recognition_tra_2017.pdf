    <meta name="citation_reference" content="citation_title=Grundintelligenztest Skala 2 (CFT 20-R) mit Wortschatztest (WS) und Zahlenfolgentest (ZF) - Revision; citation_publication_date=2006; citation_id=CR100; citation_author=RH Weiss; citation_publisher=G&#246;ttingen, Germany"/>
